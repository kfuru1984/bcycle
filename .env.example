# e-Stat API
# 取得: https://www.e-stat.go.jp/api/api-info/api-guide
ESTAT_APP_ID=your_estat_app_id_here

# FRED API
# 取得: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BOK ECOS API (韓国銀行 経済統計システム)
# 取得: https://ecos.bok.or.kr/api/#/ → 회원가입 → 서비스 신청
ECOS_API_KEY=your_ecos_api_key_here

# 既定のデータソース (estat / fred / bloomberg)
DATA_SOURCE_PREFER=estat

# Bloomberg は Terminal 環境でのみ自動検出
